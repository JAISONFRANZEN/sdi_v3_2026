# Configuração do Banco de Dados MySQL
DATABASE_URL="mysql://user:password@localhost:3306/checklist_db"

# Configuração do Backend
PORT=3000
JWT_SECRET="troque_esta_chave_secreta"

# Configuração do Frontend (Vite) — usado apenas em desenvolvimento.
# Em produção o frontend é servido pelo mesmo servidor do backend (caminho relativo).
VITE_API_URL="http://localhost:3000/api/trpc"

# --- Variáveis usadas pelo docker-compose.yml (crie um .env na raiz) ---
DB_ROOT_PASSWORD="root_password_segura"
DB_NAME="checklist_db"
DB_USER="checklist_user"
DB_PASSWORD="checklist_password_segura"
